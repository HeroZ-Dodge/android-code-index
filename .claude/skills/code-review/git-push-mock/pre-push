#!/bin/bash

# 检查是否是后台 auto-push 触发的（防止递归）
if [ "$SKIP_HOOK" = "1" ]; then
    echo "🔄 Background auto-push detected, skipping review..."
    exit 0
fi

# 记录 hook 调用日志
echo "[$(date '+%Y-%m-%d %H:%M:%S')] Pre-push hook triggered" >> /tmp/git-hook-debug.log
echo "  Working directory: $(pwd)" >> /tmp/git-hook-debug.log
echo "  Remote: $1" >> /tmp/git-hook-debug.log
echo "  URL: $2" >> /tmp/git-hook-debug.log
echo "  Branch: $(git symbolic-ref --short -q HEAD)" >> /tmp/git-hook-debug.log
echo "  Called from: ${GIT_EDITOR:-command-line}" >> /tmp/git-hook-debug.log
echo "---" >> /tmp/git-hook-debug.log

remote="$1"
url="$2"
branch=$(git symbolic-ref --short -q HEAD)

# 读取配置文件
CONFIG_FILE=".claude/skills/code-review/code-review-config.sh"
if [ ! -f "$CONFIG_FILE" ]; then
    # 兼容旧路径
    CONFIG_FILE=".code-review-config.sh"
fi

if [ -f "$CONFIG_FILE" ]; then
    source "$CONFIG_FILE"
else
    # 默认配置
    AUTO_PUSH_AFTER_FIX=false
    REVIEW_ONLY_LAST_COMMIT=false
    SKIP_MERGE_COMMIT_REVIEW=true
fi

strB="BUILD SUCCESSFUL"
echo "current branch:$branch"

#尝试读取指定的JAVA_HOME配置
config="./local.properties"
echo "config path: ${config}"
# 定义一个函数从properties文件读取key
function prop {
    [ -f "$config" ] && grep -E "^\s*[^#]?${1}=.*$" $config | cut -d'=' -f2
}

hookJavaHome=$(prop "hook.gradle.jdk.home")
echo "$hookJavaHome"
if [ -n "$hookJavaHome" ]; then
    export JAVA_HOME="$hookJavaHome"
fi
if [ -z "$hookJavaHome" ]; then
    echo "hookJavaHome is empty"
    config="./gradle.properties"
    echo "config path: ${config}"

    spJavaHome=$(prop "org.gradle.java.home")
    echo "$spJavaHome"
    if [ -n "$spJavaHome" ]; then
        export JAVA_HOME="$spJavaHome"
    fi
    if [ -z "$spJavaHome" ]; then
        echo "spJavaHome is empty"
    fi
fi

tempLog=/tmp/$(date +%s).log && touch $tempLog
if [[ "$branch" =~ (^develop$)|(^release/*) ]]; then
  ./gradlew ComponentPublishDebug | tee $tempLog
  result=$(cat $tempLog)
  checkStr=$(echo "$result" | grep "${strB}")
  if [[ "$checkStr" != ""  ]]; then
    exit 0;
  else
    exit 1;
  fi
fi


# ============================================================
# Pre-push Hook with Claude AI Code Review
# ============================================================
# 在 git push 前使用 Claude AI 进行代码审查并自动修复问题
# ============================================================

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

echo -e "${CYAN}╔════════════════════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║                                                            ║${NC}"
echo -e "${CYAN}║        🤖 Claude AI Code Review (Pre-Push)                ║${NC}"
echo -e "${CYAN}║                                                            ║${NC}"
echo -e "${CYAN}╚════════════════════════════════════════════════════════════╝${NC}"

# 获取参数
remote="$1"
url="$2"
branch=$(git symbolic-ref --short -q HEAD)

echo -e "${BLUE}📍 Branch: ${branch}${NC}"
echo -e "${BLUE}🌐 Remote: ${remote} (${url})${NC}"
echo ""

# ============================================================
# 第一步：获取未推送的文件
# ============================================================

echo -e "${GREEN}[1/3] 🔍 Analyzing unpushed commits...${NC}"

remote_branch="${remote}/${branch}"

# 根据配置决定审查范围
if [ "$REVIEW_ONLY_LAST_COMMIT" = "true" ]; then
    echo -e "${BLUE}📌 Review scope: Last commit only${NC}"
    CHANGED_FILES=$(git diff --name-only --diff-filter=ACM HEAD~1..HEAD | grep -E '\.(kt|java)$' || true)
else
    echo -e "${BLUE}📌 Review scope: All unpushed commits${NC}"
    if ! git rev-parse --verify "${remote_branch}" > /dev/null 2>&1; then
        echo -e "${YELLOW}⚠️  Remote branch not found, checking all local changes${NC}"
        CHANGED_FILES=$(git diff --name-only --diff-filter=ACM $(git merge-base HEAD origin/develop 2>/dev/null || echo HEAD)..HEAD | grep -E '\.(kt|java)$' || true)
    else
        CHANGED_FILES=$(git diff --name-only --diff-filter=ACM "${remote_branch}..HEAD" | grep -E '\.(kt|java)$' || true)
    fi
fi

if [ -z "$CHANGED_FILES" ]; then
    echo -e "${YELLOW}ℹ️  No Kotlin/Java files changed, skipping review${NC}"
    echo -e "${GREEN}✅ Push allowed${NC}"
    exit 0
fi

FILE_COUNT=$(echo "$CHANGED_FILES" | wc -l | tr -d ' ')
echo -e "${GREEN}📝 Found ${FILE_COUNT} file(s) to review${NC}"

# 检查是否跳过 merge 提交
if [ "$SKIP_MERGE_COMMIT_REVIEW" = "true" ]; then
    # 检查最近的提交是否是 merge 提交
    if [ "$REVIEW_ONLY_LAST_COMMIT" = "true" ]; then
        # 只检查最后一个提交
        MERGE_COMMIT=$(git log -1 --pretty=%P HEAD | wc -w | tr -d ' ')
    else
        # 检查所有未推送的提交中是否有 merge 提交
        if ! git rev-parse --verify "${remote_branch}" > /dev/null 2>&1; then
            MERGE_COMMIT=$(git log $(git merge-base HEAD origin/develop 2>/dev/null || echo HEAD)..HEAD --merges --oneline | wc -l | tr -d ' ')
        else
            MERGE_COMMIT=$(git log "${remote_branch}..HEAD" --merges --oneline | wc -l | tr -d ' ')
        fi
    fi

    if [ "$MERGE_COMMIT" -gt 1 ] || ([ "$REVIEW_ONLY_LAST_COMMIT" = "true" ] && [ "$MERGE_COMMIT" -gt 1 ]); then
        echo -e "${CYAN}ℹ️  Detected merge commit(s), skipping review (SKIP_MERGE_COMMIT_REVIEW=true)${NC}"
        echo -e "${GREEN}✅ Push allowed${NC}"
        exit 0
    fi
fi

# ============================================================
# 第二步：Claude AI 深度审查
# ============================================================

echo -e "\n${GREEN}[2/3] 🤖 Claude AI Code Review${NC}"
echo -e "${BLUE}📊 Analyzing ${FILE_COUNT} file(s) with Claude AI...${NC}"
echo -e "${YELLOW}⏱️  This may take 10-30 seconds...${NC}\n"

# 创建临时文件
REVIEW_PROMPT=$(mktemp)
REVIEW_RESULT=$(mktemp)

# 读取自定义 Prompt 文件
CUSTOM_PROMPT_FILE=".claude/skills/code-review/review-prompt.md"
if [ ! -f "$CUSTOM_PROMPT_FILE" ]; then
    # 兼容旧路径
    CUSTOM_PROMPT_FILE="hooks/review-prompt.md"
    if [ ! -f "$CUSTOM_PROMPT_FILE" ]; then
        echo -e "${RED}❌ Prompt file not found: .claude/skills/code-review/review-prompt.md${NC}"
        rm -f "$REVIEW_PROMPT" "$REVIEW_RESULT"
        echo -e "${YELLOW}⚠️  Continuing without review...${NC}"
        exit 0
    fi
fi

# 构建审查提示（从文件读取）
cat "$CUSTOM_PROMPT_FILE" > "$REVIEW_PROMPT"
echo -e "\n\n## 待审查的代码\n" >> "$REVIEW_PROMPT"

# 添加所有文件的 diff（而不是完整内容）
echo "$CHANGED_FILES" | while IFS= read -r file; do
    if [ -f "$file" ]; then
        echo -e "\n### 📄 File: $file\n" >> "$REVIEW_PROMPT"

        # 获取这个文件在未推送 commits 中的 diff
        if ! git rev-parse --verify "${remote_branch}" > /dev/null 2>&1; then
            DIFF=$(git diff $(git merge-base HEAD origin/develop 2>/dev/null || echo HEAD) HEAD -- "$file")
        else
            DIFF=$(git diff "${remote_branch}..HEAD" -- "$file")
        fi

        if [ -n "$DIFF" ]; then
            echo '```diff' >> "$REVIEW_PROMPT"
            echo "$DIFF" >> "$REVIEW_PROMPT"
            echo '```' >> "$REVIEW_PROMPT"
        else
            # 如果没有 diff，显示整个文件（可能是新文件）
            echo '```kotlin' >> "$REVIEW_PROMPT"
            head -200 "$file" >> "$REVIEW_PROMPT"  # 限制最多 200 行
            echo '```' >> "$REVIEW_PROMPT"
        fi
        echo "" >> "$REVIEW_PROMPT"
    fi
done

# 调用 Claude AI
echo -e "${YELLOW}⏳ Calling Claude AI...${NC}"
claude --print < "$REVIEW_PROMPT" > "$REVIEW_RESULT" 2>&1
CLAUDE_EXIT_CODE=$?

echo -e "${BLUE}📊 Claude exit code: ${CLAUDE_EXIT_CODE}${NC}"

# 检查是否成功
if [ $CLAUDE_EXIT_CODE -ne 0 ]; then
    echo -e "${RED}❌ Claude AI review failed with exit code: ${CLAUDE_EXIT_CODE}${NC}"
    echo -e "${YELLOW}Error output:${NC}"
    cat "$REVIEW_RESULT"
    rm -f "$REVIEW_PROMPT" "$REVIEW_RESULT"
    echo -e "${YELLOW}⚠️  Continuing without review...${NC}"
    exit 0
fi

if [ ! -s "$REVIEW_RESULT" ]; then
    echo -e "${RED}❌ Claude AI returned empty result${NC}"
    rm -f "$REVIEW_PROMPT" "$REVIEW_RESULT"
    echo -e "${YELLOW}⚠️  Continuing without review...${NC}"
    exit 0
fi

# 显示审查结果
echo -e "${CYAN}═══════════════════════════════════════════════════${NC}"
echo -e "${GREEN}📋 Claude AI Review Results:${NC}"
echo -e "${CYAN}═══════════════════════════════════════════════════${NC}\n"

cat "$REVIEW_RESULT"

echo -e "\n${CYAN}═══════════════════════════════════════════════════${NC}"

# 保存审查日志
REVIEW_LOG_DIR=".code-review-logs"
mkdir -p "$REVIEW_LOG_DIR"
TIMESTAMP=$(date +"%Y-%m-%d_%H-%M-%S")
cp "$REVIEW_RESULT" "$REVIEW_LOG_DIR/${TIMESTAMP}_review.log"
cp "$REVIEW_RESULT" "$REVIEW_LOG_DIR/latest.log"

echo -e "\n${BLUE}💾 Review log saved to: ${REVIEW_LOG_DIR}/${TIMESTAMP}_review.log${NC}"

# 清理旧的 review log，只保留最新的 3 条（不包括 latest.log）
LOG_COUNT=$(ls -1 "$REVIEW_LOG_DIR"/*_review.log 2>/dev/null | wc -l | tr -d ' ')
if [ "$LOG_COUNT" -gt 3 ]; then
    # 获取最旧的日志文件并删除
    LOGS_TO_DELETE=$((LOG_COUNT - 3))
    ls -1t "$REVIEW_LOG_DIR"/*_review.log | tail -n "$LOGS_TO_DELETE" | while IFS= read -r old_log; do
        echo -e "${YELLOW}🗑️  Removing old log: $(basename "$old_log")${NC}"
        rm -f "$old_log"
    done
fi

# ============================================================
# 第三步：自动修复
# ============================================================

echo -e "\n${GREEN}[3/3] 🔧 Auto-fixing issues...${NC}"

# 提取 JSON（去除可能的 markdown 代码块标记）
JSON_CONTENT=$(cat "$REVIEW_RESULT" | sed -n '/```json/,/```/p' | sed '1d;$d')

if [ -z "$JSON_CONTENT" ]; then
    # 尝试直接提取（如果没有 markdown 代码块）
    JSON_CONTENT=$(cat "$REVIEW_RESULT" | sed -n '/^{/,/^}/p')
fi

if [ -n "$JSON_CONTENT" ] && echo "$JSON_CONTENT" | jq -e . > /dev/null 2>&1; then
    # 检查是否有 auto_fixes
    AUTO_FIX_COUNT=$(echo "$JSON_CONTENT" | jq -r '.auto_fixes | length' 2>/dev/null || echo "0")

    if [ "$AUTO_FIX_COUNT" -gt 0 ]; then
        echo -e "${BLUE}📝 Found ${AUTO_FIX_COUNT} auto-fixable issue(s)${NC}"

        FIXED_FILES=()
        FILES_CHANGED=false

        # 遍历每个 auto_fix
        for i in $(seq 0 $((AUTO_FIX_COUNT - 1))); do
            FILE_PATH=$(echo "$JSON_CONTENT" | jq -r ".auto_fixes[$i].file")
            DESCRIPTION=$(echo "$JSON_CONTENT" | jq -r ".auto_fixes[$i].description")
            SEARCH_TEXT=$(echo "$JSON_CONTENT" | jq -r ".auto_fixes[$i].search")
            REPLACE_TEXT=$(echo "$JSON_CONTENT" | jq -r ".auto_fixes[$i].replace")

            if [ -f "$FILE_PATH" ] && [ "$SEARCH_TEXT" != "null" ] && [ "$REPLACE_TEXT" != "null" ]; then
                echo -e "${BLUE}  🔧 Fixing: ${DESCRIPTION}${NC}"

                # 使用 Python 进行智能替换（支持多行，忽略缩进差异）
                python3 << PYTHON_SCRIPT
import re

# 读取文件
with open("$FILE_PATH", 'r', encoding='utf-8') as f:
    content = f.read()

# 搜索和替换文本
search_text = """$SEARCH_TEXT"""
replace_text = """$REPLACE_TEXT"""

# 移除搜索文本和文件内容中的前导空格进行模糊匹配
def normalize_for_search(text):
    lines = text.split('\\n')
    # 移除每行的前导空格，但保留相对缩进
    if lines:
        min_indent = min(len(line) - len(line.lstrip()) for line in lines if line.strip())
        normalized = '\\n'.join(line[min_indent:] if len(line) > min_indent else line for line in lines)
        return normalized
    return text

# 尝试直接替换
if search_text in content:
    new_content = content.replace(search_text, replace_text)
    with open("$FILE_PATH", 'w', encoding='utf-8') as f:
        f.write(new_content)
    exit(0)
else:
    # 尝试忽略缩进的模糊匹配
    search_normalized = normalize_for_search(search_text)

    # 在文件中查找匹配的块
    lines = content.split('\\n')
    for start_idx in range(len(lines)):
        # 提取候选块
        candidate_lines = lines[start_idx:start_idx + search_text.count('\\n') + 1]
        candidate_block = '\\n'.join(candidate_lines)
        candidate_normalized = normalize_for_search(candidate_block)

        if candidate_normalized.strip() == search_normalized.strip():
            # 找到匹配，保留原始缩进
            if candidate_lines and candidate_lines[0]:
                leading_spaces = len(candidate_lines[0]) - len(candidate_lines[0].lstrip())
                replace_lines = replace_text.split('\\n')
                indented_replace = '\\n'.join(' ' * leading_spaces + line if line.strip() else line for line in replace_lines)
            else:
                indented_replace = replace_text

            # 执行替换
            new_lines = lines[:start_idx] + indented_replace.split('\\n') + lines[start_idx + len(candidate_lines):]
            new_content = '\\n'.join(new_lines)

            with open("$FILE_PATH", 'w', encoding='utf-8') as f:
                f.write(new_content)
            exit(0)

    # 未找到匹配
    exit(1)
PYTHON_SCRIPT

                if [ $? -eq 0 ]; then
                    echo -e "${GREEN}     ✓ Fixed in ${FILE_PATH}${NC}"
                    FIXED_FILES+=("$FILE_PATH")
                    FILES_CHANGED=true
                else
                    echo -e "${YELLOW}     ⚠️  Could not apply fix automatically${NC}"
                fi
            fi
        done

        # 如果有文件被修改，创建 auto-fix commit
        if [ "$FILES_CHANGED" = true ]; then
            echo -e "\n${GREEN}💾 Creating auto-fix commit...${NC}"

            # 添加修改的文件
            for file in "${FIXED_FILES[@]}"; do
                git add "$file"
            done

            # 创建 commit
            COMMIT_MSG="#0 [auto-fix] Code review fixes before push

Applied automatic fixes from Claude AI code review:
- Fixed ${AUTO_FIX_COUNT} issue(s)

🤖 Generated with Claude Code
Co-Authored-By: Claude <noreply@anthropic.com>"

            if git commit -m "$COMMIT_MSG" > /dev/null 2>&1; then
                echo -e "${GREEN}✅ Auto-fix commit created successfully${NC}"

                # 清理临时文件
                rm -f "$REVIEW_PROMPT" "$REVIEW_RESULT"

                # 根据配置决定是否自动 push
                if [ "$AUTO_PUSH_AFTER_FIX" = "true" ]; then
                    echo -e "${GREEN}🚀 Allowing push to continue with auto-fix commit...${NC}"
                    echo -e "${BLUE}ℹ️  The original push will include the auto-fix commit${NC}"

                    # 返回 0 允许原始 push 继续（它会推送包括 auto-fix commit 在内的所有 commits）
                    exit 0
                else
                    echo -e "${YELLOW}⚠️  New commit created, please run 'git push' again${NC}"

                    # 为 SourceTree 和 IDE 显示友好的错误消息
                    echo ""
                    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                    echo "🤖 Claude AI Code Review: Auto-fix Applied"
                    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                    echo ""
                    echo "✅ Code issues have been automatically fixed!"
                    echo "📝 A new commit has been created: #0 [auto-fix]"
                    echo ""
                    echo "📌 Next steps:"
                    echo "   1. Review the auto-fix commit (if needed)"
                    echo "   2. Push again to upload all changes"
                    echo ""
                    echo "💡 Tip: Run 'git log -2' to see the fix details"
                    echo ""
                    echo "⚙️  Want auto-push? Set AUTO_PUSH_AFTER_FIX=true in .code-review-config.sh"
                    echo ""
                    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

                    # 清理临时文件
                    rm -f "$REVIEW_PROMPT" "$REVIEW_RESULT"

                    # 退出，让用户重新 push
                    exit 1
                fi
            else
                echo -e "${RED}❌ Failed to create auto-fix commit${NC}"
            fi
        else
            echo -e "${YELLOW}ℹ️  No files were modified${NC}"
        fi
    else
        echo -e "${YELLOW}ℹ️  No auto-fixable issues found${NC}"
    fi
else
    echo -e "${YELLOW}⚠️  Could not parse review result as JSON, skipping auto-fix${NC}"
fi

echo -e "\n${GREEN}✅ Review and auto-fix completed${NC}"

# 清理临时文件
rm -f "$REVIEW_PROMPT" "$REVIEW_RESULT"

# ============================================================
# 最终输出
# ============================================================

echo -e "\n${CYAN}╔════════════════════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║                                                            ║${NC}"
echo -e "${CYAN}║           ✅ Claude AI Review Completed                    ║${NC}"
echo -e "${CYAN}║                                                            ║${NC}"
echo -e "${CYAN}╚════════════════════════════════════════════════════════════╝${NC}"

# 允许 push
exit 0
